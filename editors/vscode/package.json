{
  "name": "prior-lang",
  "displayName": "PRIOR",
  "description": "Language support for PRIOR trading strategies: syntax highlighting, completions, hovers, diagnostics, and formatting.",
  "version": "0.1.3",
  "icon": "icon.png",
  "publisher": "autoquant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prior-lang/prior"
  },
  "homepage": "https://autoquant.ai/prior",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "trading",
    "backtesting",
    "quant",
    "strategy",
    "prior"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "prior",
        "aliases": [
          "PRIOR",
          "prior"
        ],
        "extensions": [
          ".prior"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "prior",
        "scopeName": "source.prior",
        "path": "./syntaxes/prior.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "prior",
        "path": "./snippets/prior.json"
      }
    ],
    "configuration": {
      "title": "PRIOR",
      "properties": {
        "prior.command": {
          "type": "string",
          "default": "prior",
          "description": "Command used to run the prior CLI for diagnostics and formatting. Falls back to `python3 -m prior_lang.cli` if not found. Install with: pip install prior-lang"
        },
        "prior.validateOnType": {
          "type": "boolean",
          "default": true,
          "description": "Run prior validate as you type (debounced). Turn off to validate only on save."
        }
      }
    },
    "configurationDefaults": {
      "[prior]": {
        "editor.defaultFormatter": "autoquant.prior-lang"
      }
    }
  }
}